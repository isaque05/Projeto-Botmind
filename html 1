<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Chatbot (Frontend) — Exemplo</title>
  <style>
    :root{--bg:#0f1724;--card:#0b1220;--accent:#06b6d4;--muted:#94a3b8;--me:#083344}
    *{box-sizing:border-box;font-family:Inter,system-ui,Arial,Helvetica,sans-serif}
    body{margin:0;background:linear-gradient(180deg,#071022, #071a2a);color:#e6eef6;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}
    .app{width:100%;max-width:880px;background:rgba(255,255,255,0.03);border-radius:12px;box-shadow:0 10px 30px rgba(2,6,23,0.6);overflow:hidden}
    header{display:flex;justify-content:space-between;align-items:center;padding:14px 18px;border-bottom:1px solid rgba(255,255,255,0.03)}
    header h1{font-size:16px;margin:0}
    .main{display:grid;grid-template-columns:1fr 320px;min-height:480px}
    .chat{padding:18px;display:flex;flex-direction:column;gap:12px}
    .messages{flex:1;overflow:auto;padding-right:6px}
    .message{max-width:78%;padding:10px 12px;border-radius:10px;margin-bottom:10px;line-height:1.35}
    .me{margin-left:auto;background:linear-gradient(180deg,var(--accent),#0aa9c2);color:#04232f}
    .bot{background:rgba(255,255,255,0.03);color:var(--muted)}
    .controls{display:flex;gap:8px;padding:12px;border-top:1px solid rgba(255,255,255,0.02)}
    .controls input{flex:1;padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.03);background:transparent;color:inherit}
    button{background:var(--accent);border:none;padding:10px 14px;border-radius:8px;color:#03202a;font-weight:600;cursor:pointer}
    aside{background:rgba(0,0,0,0.06);padding:14px;border-left:1px solid rgba(255,255,255,0.02)}
    label{display:block;font-size:13px;color:var(--muted);margin-bottom:6px}
    .field{margin-bottom:10px}
    .small{font-size:12px;color:var(--muted)}
    .status{font-size:13px;padding:6px 8px;border-radius:8px;background:rgba(255,255,255,0.02);display:inline-block}
    .footer-note{font-size:12px;color:var(--muted);padding:8px}
    .controls .btn-aux{background:transparent;border:1px solid rgba(255,255,255,0.04);color:var(--muted)}
  </style>
</head>
<body>
  <div class="app" role="application">
    <header>
      <h1>Chatbot — Frontend (exemplo)</h1>
      <div class="status" id="status">Desconectado</div>
    </header>

    <div class="main">
      <section class="chat" aria-label="Área do chat">
        <div class="messages" id="messages" aria-live="polite"></div>

        <div class="controls">
          <input id="input" placeholder="Digite sua mensagem..." autocomplete="off" />
          <button id="send">Enviar</button>
          <button id="clear" class="btn-aux">Limpar</button>
        </div>
      </section>

      <aside>
        <div class="field">
          <label>API URL</label>
          <input id="apiUrl" placeholder="Ex: https://meu-backend.ex/api/gemini" />
          <div class="small">Deixe em branco para usar modo de exemplo (mock).</div>
        </div>
        <div class="field">
          <label>API Key (opcional)</label>
          <input id="apiKey" placeholder="Coloque sua chave se precisar de auth" />
          <div class="small">Se seu backend exigir Authorization, informe a chave aqui.</div>
        </div>
        <div class="field">
          <label>Formato da requisição</label>
          <select id="payloadFormat">
            <option value="generic">Genérico JSON: { input: string }</option>
            <option value="gemini">Gemini (ajuste conforme docs)</option>
          </select>
        </div>

        <div style="margin-top:10px">
          <button id="save">Salvar configurações</button>
          <button id="restore" class="btn-aux">Restaurar padrão</button>
        </div>

        <div class="footer-note">Observação: adapte o endpoint e o body ao formato exato da API Gemini que você estiver usando. Arquivo salvo no localStorage do navegador.</div>
      </aside>
    </div>
  </div>

  <script>
    // ===== CONFIGURÁVEIS =====
    // Este arquivo já permite você inserir API_URL e API_KEY pelo painel lateral.
    // Por padrão, se API_URL estiver em branco, o front usa um mock local para demonstração.

    const $messages = document.getElementById('messages');
    const $input = document.getElementById('input');
    const $send = document.getElementById('send');
    const $clear = document.getElementById('clear');
    const $status = document.getElementById('status');
    const $apiUrl = document.getElementById('apiUrl');
    const $apiKey = document.getElementById('apiKey');
    const $payloadFormat = document.getElementById('payloadFormat');
    const $save = document.getElementById('save');
    const $restore = document.getElementById('restore');

    // Carrega configurações do localStorage (se existir)
    function loadSettings(){
      try{
        const s = JSON.parse(localStorage.getItem('chat_settings')||'{}');
        $apiUrl.value = s.apiUrl||'';
        $apiKey.value = s.apiKey||'';
        $payloadFormat.value = s.payloadFormat||'generic';
        updateStatus();
      }catch(e){console.warn(e)}
    }
    function saveSettings(){
      const s = {apiUrl: $apiUrl.value.trim(), apiKey: $apiKey.value.trim(), payloadFormat: $payloadFormat.value};
      localStorage.setItem('chat_settings', JSON.stringify(s));
      updateStatus();
      alert('Configurações salvas no navegador.');
    }
    function restoreDefaults(){
      localStorage.removeItem('chat_settings');
      loadSettings();
      alert('Configurações restauradas.');
    }

    function updateStatus(){
      const url = $apiUrl.value.trim();
      if(!url){ $status.textContent = 'Modo demo (mock)'; }
      else{ $status.textContent = 'Endpoint: ' + url; }
    }

    // Renderiza uma mensagem (tipo: me | bot)
    function addMessage(text, type='bot'){
      const el = document.createElement('div');
      el.className = 'message ' + (type==='me' ? 'me' : 'bot');
      el.textContent = text;
      $messages.appendChild(el);
      $messages.scrollTop = $messages.scrollHeight;
    }

    // Envia mensagem para a API
    async function sendMessage(){
      const text = $input.value.trim();
      if(!text) return;
      addMessage(text, 'me');
      $input.value = '';

      // Mostra indicador de digitação do bot
      const typing = document.createElement('div');
      typing.className = 'message bot';
      typing.textContent = '...';
      $messages.appendChild(typing);
      $messages.scrollTop = $messages.scrollHeight;

      try{
        const reply = await callAPI(text);
        typing.remove();
        addMessage(reply||'(sem resposta)', 'bot');
      }catch(err){
        typing.remove();
        addMessage('Erro: ' + (err.message||err), 'bot');
        console.error(err);
      }
    }

    // Função que chama o endpoint configurado.
    async function callAPI(message){
      const apiUrl = $apiUrl.value.trim();
      const apiKey = $apiKey.value.trim();
      const fmt = $payloadFormat.value;

      // Modo DEMO/MOCK quando apiUrl não informado. Útil para testar sem backend.
      if(!apiUrl){
        // Simula latência e resposta
        await new Promise(r => setTimeout(r, 700));
        return 'Resposta de demonstração para: "' + message + '"';
      }

      // Monta o body dependendo do formato selecionado. Ajuste conforme necessário.
      let body;
      if(fmt === 'generic'){
        body = { input: message };
      } else if(fmt === 'gemini'){
        // Exemplo genérico (NÃO é garantido ser o formato exato do Gemini da sua conta).
        // Consulte a documentação oficial do Gemini e adapte o objeto abaixo ao que sua API espera.
        body = {
          prompt: message,
          // model: 'gemini-1.0', // descomente/ajuste se necessário
          // temperature: 0.2
        };
      }

      const headers = {'Content-Type': 'application/json'};
      if(apiKey) headers['Authorization'] = 'Bearer ' + apiKey;

      const res = await fetch(apiUrl, {
        method: 'POST',
        headers,
        body: JSON.stringify(body)
      });

      if(!res.ok){
        const txt = await res.text();
        throw new Error('Status ' + res.status + ' - ' + txt.slice(0,400));
      }

      // Tenta interpretar resposta nas formas mais comuns
      const ct = res.headers.get('content-type') || '';
      if(ct.includes('application/json')){
        const j = await res.json();
        // Muitas APIs retornam {output: 'texto'} ou {choices:[{text: '...'}]} ou {choices:[{message:{content:'...'}}]}
        if(j.output && typeof j.output === 'string') return j.output;
        if(j.choices && Array.isArray(j.choices)){
          const first = j.choices[0];
          if(first.text) return first.text;
          if(first.message && (first.message.content || first.message.content_text)) return first.message.content || first.message.content_text;
          if(first.delta && first.delta.content) return first.delta.content;
        }
        // Alguns endpoints usam 'candidates' (Gemini experimental) ou 'response'
        if(j.candidates && j.candidates[0] && j.candidates[0].content) return j.candidates[0].content;
        if(j.response) return (typeof j.response === 'string') ? j.response : JSON.stringify(j.response);
        // Fallback: retorna o JSON inteiro resumido
        return JSON.stringify(j);
      }

      // Se não for JSON, tenta texto simples
      return await res.text();
    }

    // Eventos
    $send.addEventListener('click', sendMessage);
    $input.addEventListener('keydown', e => { if(e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } });
    $clear.addEventListener('click', ()=>{ $messages.innerHTML=''; });
    $save.addEventListener('click', saveSettings);
    $restore.addEventListener('click', restoreDefaults);

    // Inicialização
    loadSettings();

    // Sugestão prática: Se você estiver usando a API Gemini diretamente do navegador,
    // NÃO coloque chaves sensíveis no front-end em produção. Em vez disso, crie um backend
    // que faça proxy para a Gemini e mantenha a API Key segura.

  </script>
</body>
</html>
